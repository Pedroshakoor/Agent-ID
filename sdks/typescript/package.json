{
  "name": "@agentid/sdk",
  "version": "1.0.0",
  "description": "AgentID TypeScript SDK — verifiable identity for every AI agent",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": ["ai", "agent", "identity", "langchain", "openai", "agentid"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentid/agentid"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "msw": "^2.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.2"
  },
  "files": ["dist", "README.md", "LICENSE"]
}
